<Window x:Class="RimeDictManager.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:RimeDictManager.VMs"
    Title="RIME 词库管理器 3.0.0"
    FontSize="14"
    Height="480"
    Width="640"
    UseLayoutRounding="True">
    <Window.DataContext>
        <vm:MainVM/>
    </Window.DataContext>
    <Grid Margin="12, 11">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="29"/>
            <RowDefinition Height="11"/>
            <RowDefinition Height="29"/>
            <RowDefinition Height="11"/>
            <RowDefinition Height="29"/>
            <RowDefinition Height="11"/>
            <RowDefinition Height="29"/>
            <RowDefinition Height="11"/>
            <RowDefinition Height="29"/>
            <RowDefinition Height="11"/>
            <RowDefinition Height="29"/>
            <RowDefinition Height="11"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Button AllowDrop="True"
            Content="打开词库"
            ToolTip="支持拖放"
            Command="{Binding OpenCommand, Mode=OneTime}"
            Drop="DropDict"/>
        <ComboBox Grid.Column="0"
            Grid.Row="2"
            VerticalContentAlignment="Center"
            ToolTip="编码方案名"
            IsEnabled="{Binding EncoderEnabled}"
            ItemsSource="{Binding EncodeMethods, Mode=OneTime}"
            SelectedItem="{Binding SelEncodeMethod, Mode=OneWayToSource}"/>
        <Button Grid.Column="0"
            Grid.Row="4"
            Content="更换单字"
            ToolTip="支持拖放"
            Command="{Binding ChangeSingleCommand, Mode=OneTime}"
            Drop="DropCharsDict"/>
        <Button Grid.Column="0"
            Grid.Row="6"
            Content="查看日志"
            Click="ShowLogs"/>
        <Button Grid.Column="0"
            Grid.Row="8"
            Content="保存词库"
            Command="{Binding SaveCommand, Mode=OneTime}"/>
        <TextBox Grid.Column="2"
            Grid.ColumnSpan="4"
            Grid.Row="0"
            ToolTip="待添加的字词"
            Text="{Binding PendingText, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
        <RadioButton Grid.Column="2"
            Grid.Row="2"
            Margin="4, 0, 8, 0"
            Padding="0"
            Content="自动编码"
            GroupName="EncodeMode"
            IsChecked="{Binding EncoderEnabled}"/>
        <Slider Grid.Column="5"
            Grid.Row="2"
            VerticalAlignment="Center"
            IsSnapToTickEnabled="True"
            AutoToolTipPlacement="BottomRight"
            TickPlacement="TopLeft"
            ToolTip="自动编码的码长"
            IsEnabled="{Binding EncoderEnabled}"
            Minimum="{Binding CodeLenMin}"
            Maximum="{Binding CodeLenMax}"
            Value="{Binding CodeLen}"/>
        <ComboBox Grid.Column="3"
            Grid.Row="2"
            VerticalContentAlignment="Center"
            ToolTip="自动编码结果；变红表示不唯一"
            Foreground="{Binding AutoCodeColor}"
            IsEnabled="{Binding EncoderEnabled}"
            ItemsSource="{Binding AutoCodes}"
            SelectedItem="{Binding SelAutoCode}"/>
        <RadioButton Grid.Column="2"
            Grid.Row="4"
            Margin="4, 0, 8, 0"
            Padding="0"
            Content="手动编码"
            GroupName="EncodeMode"
            IsChecked="True"/>
        <TextBox Grid.Column="3"
            Grid.Row="4"
            Text="{Binding ManualCode, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
        <Label Grid.Column="2"
            Grid.Row="6"
            Margin="8, 0"
            Padding="0"
            VerticalAlignment="Center"
            Content="权重（可选）"/>
        <TextBox Grid.Column="3"
            Grid.Row="6"
            ToolTip="格式：'非负整数'或'浮点数%'"
            Text="{Binding PendingWeight, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
        <Label Grid.Column="2"
            Grid.Row="8"
            Margin="1, 0"
            Padding="0"
            VerticalAlignment="Center"
            Content="造词码（可选）"/>
        <TextBox Grid.Column="3"
            Grid.Row="8"
            Text="{Binding PendingStem, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"/>
        <Button Grid.Column="5"
            Grid.Row="4"
            Content="添加词条"
            Command="{Binding InsertCommand, Mode=OneTime}"/>
        <Button Grid.Column="5"
            Grid.Row="6"
            Content="删除词条"
            Command="{Binding RemoveCommand, Mode=OneTime}"/>
        <Button Grid.Column="5"
            Grid.Row="8"
            Content="截短编码"
            ToolTip="将选中词条的编码截短为搜索框中的编码&#x000A;若有一个词条占用该短码，则将其编码顺延至最短的余位&#x000A;需开启自动编码和编码前缀搜索；仅用于变长编码方案"
            Command="{Binding ShortenCommand, Mode=OneTime}"/>
        <Button Grid.Column="5"
            Grid.Row="10"
            Content="应用修改"
            ToolTip="应用在表格中的手动修改"
            Command="{Binding ModifyCommand, Mode=OneTime}"/>
        <RadioButton Grid.Column="0"
            Grid.Row="10"
            Margin="0"
            Padding="0"
            Content="按编码前缀"
            GroupName="SearchMode"
            IsChecked="{Binding IsSearchByCode}"/>
        <RadioButton Grid.Column="1"
            Grid.ColumnSpan="2"
            Grid.Row="10"
            Margin="6, 0"
            Padding="0"
            Content="按词组精确"
            GroupName="SearchMode"/>
        <TextBox Grid.Column="3"
            Grid.Row="10"
            ToolTip="输入搜索内容，结果立即显示在表格中"
            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
        <DataGrid Grid.Column="0"
            Grid.ColumnSpan="6"
            Grid.Row="12"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            SelectionMode="Single"
            ItemsSource="{Binding SearchResults}"
            SelectedItem="{Binding SelSearchResult}">
            <DataGrid.Columns>
                <DataGridTextColumn Width="100"
                    IsReadOnly="True"
                    Header="行号"
                    Binding="{Binding Num}"/>
                <DataGridTextColumn Width="*"
                    Header="词组"
                    Binding="{Binding Text}"/>
                <DataGridTextColumn Width="*"
                    Header="编码"
                    Binding="{Binding Code}"/>
                <DataGridTextColumn Width="100"
                    Header="权重"
                    Binding="{Binding Weight}"/>
                <DataGridTextColumn Width="100"
                    Header="造词码"
                    Binding="{Binding Stem}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>